# ─────────────────────────────────────────────────────────────────────────────
# Portal de cliente (se sirve como SUBCARPETA de la web principal: /portal)
# ─────────────────────────────────────────────────────────────────────────────

# DEV — destino del proxy de Vite: el backend FastAPI (auth + portal + analytics).
VITE_API_TARGET=http://localhost:8000

# PROD — base de la API. OBLIGATORIO al servir el portal en /portal:
# el backend expone sus endpoints bajo /portal/*, que colisiona con la ruta
# estática /portal/ del front si comparten origen. Apunta la API a un origen
# distinto (subdominio del backend o ruta /api detrás del reverse proxy).
# VITE_API_BASE=https://api.tu-dominio.com

# PROD — ruta base del build estático. Cámbiala si no usas exactamente /portal/.
# Debe empezar y terminar con "/".
# VITE_BASE=/portal/
